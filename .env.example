# Copy to .env.local — do not commit .env.local

# Admin login is email+password against the admin_users table (no shared
# ADMIN_PASSWORD fallback anymore — see docs/HANDOFF.md). Seed a local admin
# user via the API's seed-admin script (SUPERADMIN_EMAIL/SUPERADMIN_PASSWORD).

# Soul Thread API
API_BASE_URL=http://localhost:3001
API_INTERNAL_TOKEN=dev-token-change-me

# Platform storefront domain — used to build "View store" links in the sidebar.
# Store URLs are constructed as https://<slug>.<NEXT_PUBLIC_PLATFORM_DOMAIN>
NEXT_PUBLIC_PLATFORM_DOMAIN=store.helloworldnepal.com

# Secret sent to the storefront's /api/revalidate endpoint after template/settings changes.
# Must match REVALIDATE_SECRET in the storefront's Vercel env vars.
REVALIDATE_SECRET=dev-revalidate-secret

# Sentry (optional — error tracking disabled if unset). Use a project separate
# from the bikribazzar-api one (Next.js vs. .NET). DSN is not a secret.
NEXT_PUBLIC_SENTRY_DSN=
# Only needed to upload source maps at build time (nicer stack traces in Sentry).
# Leave unset to skip source map upload — the build still succeeds.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN==
