# ─── Admin console — Production Environment (self-hosted on VPS) ─────────────
# Copy this to .env on the server, inside the same directory as docker-compose.yml
# (e.g. ~/soul-thread-admin/.env — NOT committed, NOT scp'd by CI).
# Usage: docker compose --env-file .env up -d admin

# Must match bikribazaar-api's API_INTERNAL_TOKEN.
API_INTERNAL_TOKEN=

# Must match the storefront's REVALIDATE_SECRET (sent to its /api/revalidate
# endpoint after template/settings changes).
REVALIDATE_SECRET=

# Used to build "View store" links (https://<slug>.<this>) in the sidebar.
NEXT_PUBLIC_PLATFORM_DOMAIN=bikribazaar.com
NEXT_PUBLIC_PLATFORM_NAME=Bikri Bazaar

# Sentry (optional — error tracking disabled if unset). DSN is not a secret.
NEXT_PUBLIC_SENTRY_DSN=
